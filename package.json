{
  "name": "olm-console-plugin",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && NODE_ENV=production yarn ts-node node_modules/.bin/webpack",
    "build-dev": "yarn clean && yarn ts-node node_modules/.bin/webpack",
    "http-server": "npx http-server dist -p 9001 -c-1 --cors",
    "start-console": "./start-console.sh",
    "i18n": "i18next \"src/**/*.{js,jsx,ts,tsx}\" -c i18next-parser.config.js",
    "ts-node": "ts-node -O '{\"module\":\"commonjs\"}'",
    "lint": "eslint src/ --ext .ts,.tsx"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "link:../console/frontend/packages/console-dynamic-plugin-sdk/dist/core",
    "@openshift-console/dynamic-plugin-sdk-webpack": "link:../console/frontend/packages/console-dynamic-plugin-sdk/dist/webpack",
    "@openshift-console/olm-types": "portal:./packages/olm-types",
    "@patternfly/react-catalog-view-extension": "^6.2.2",
    "@patternfly/react-charts": "^7.4.6",
    "@patternfly/react-core": "^6.2.2",
    "@patternfly/react-icons": "^6.2.2",
    "@patternfly/react-styles": "^6.2.2",
    "@patternfly/react-table": "^6.2.2",
    "@patternfly/react-templates": "^6.2.2",
    "@patternfly/react-topology": "^6.2.2",
    "@rjsf/core": "^4.2.3",
    "@types/lodash": "^4.17.0",
    "@types/node": "^22.19.7",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^5.2.7",
    "file-loader": "6.2.0",
    "i18next": "^25.8.18",
    "immutable": "^4.3.0",
    "js-yaml": "^4.1.1",
    "json-schema": "^0.4.0",
    "lodash": "^4.17.21",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "~16.5.8",
    "react-router": "~7.13.1",
    "react-router-dom": "~7.13.1",
    "redux": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "webpack": "^5.100.0",
    "webpack-cli": "^6.0.1"
  },
  "consolePlugin": {
    "name": "olm-console-plugin",
    "version": "4.19.0",
    "displayName": "Operator Lifecycle Manager",
    "description": "Console plugin for Operator Lifecycle Manager (OLM) providing operator catalog, installation, and management UI.",
    "dependencies": {
      "@console/pluginAPI": ">=4.19.0-0"
    },
    "exposedModules": {
      "CatalogRedirect": "./olm/components/catalog-redirect.tsx",
      "catalogSource": "./olm/components/catalogsource-list-page.tsx",
      "clusterServiceVersions": "./olm/components/csv-list-page.tsx",
      "createCatalogSource": "./olm/components/catalogsource-list-page.tsx",
      "createOperand": "./olm/components/operand-pages.tsx",
      "csvStatus": "./olm/components/dashboard/csv-status.tsx",
      "filters": "./olm/utils/filters.ts",
      "install": "./olm/components/operator-install-status-page.tsx",
      "installPlan": "./olm/components/installplan-list-page.tsx",
      "operand": "./olm/components/operand-pages.tsx",
      "operatorHubDetails": "./olm/components/operatorhub-page.tsx",
      "operatorHubSubscribe": "./olm/components/operatorhub-page.tsx",
      "operatorLinkTabSection": "./olm/components/topology/operator-link-tab-section.tsx",
      "packageManifest": "./olm/components/packagemanifest-list-page.tsx",
      "subscriptionProvider": "./olm/actions/providers/subscription-provider.ts",
      "subscriptions": "./olm/components/subscription-list-page.tsx",
      "topologySidebarDetailsSections": "./olm/components/topology/sidebar/details-sections.tsx",
      "topologySidebarResourceLink": "./olm/components/topology/sidebar/resource-link.tsx",
      "topologySidebarResourceSections": "./olm/components/topology/sidebar/resource-sections.tsx",
      "useClusterServiceVersions": "./olm/utils/useClusterServiceVersions.tsx",
      "useDefaultOperandActions": "./olm/actions/useDefaultOperandActions.ts",
      "useOperatorActions": "./olm/actions/useOperatorActions.ts",
      "defaultActionsProvider": "./olm/actions/providers/default-actions-provider.ts",
      "catalogSourceActionsProvider": "./olm/actions/providers/catalog-source-provider.ts",
      "useOperatorCatalogCategories": "./olm/hooks/useOperatorCatalogCategories.ts",
      "useOperatorCatalogItems": "./olm/hooks/useOperatorCatalogItems.tsx",
      "utils": "./olm/components/dashboard/utils.ts",
      "useCatalogItems": "./olmv1/hooks/useCatalogItems.ts",
      "useCatalogCategories": "./olmv1/hooks/useCatalogCategories.ts",
      "useOLMv1FlagProvider": "./olmv1/hooks/useOLMv1FlagProvider.ts",
      "CreateClusterExtension": "./olmv1/components/cluster-extension/CreateClusterExtension.tsx",
      "olmv1DefaultActionsProvider": "./olmv1/actions/providers/default-actions-provider.ts",
      "installedSoftwarePage": "./olmv1/components/installed-software/InstalledSoftwarePage.tsx"
    }
  }
}
